# ============================================
# Agentic AI Data Analysis Agent — Environment
# ============================================
# Copy this file to .env and fill in your values.

# --- Database ---
DATABASE_URL=sqlite:///./audit_agent.db

# --- File Storage ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# --- LLM (Provider-Agnostic via LiteLLM) ---
# This app uses two separate LLM slots:
#   1. LLM_MODEL / LLM_API_KEY           -> NL question -> SQL query generation
#   2. FINDINGS_LLM_MODEL / ...          -> per-finding audit explanations
# Both go through the same provider-agnostic client (app/llm/client.py), so
# switching provider is just an env var change below — no code changes needed.
#
# The default setup below (Gemini + local Ollama) is what the developer uses.
# If you only have an OpenAI or Azure OpenAI key, uncomment ONE block below
# and comment out (or delete) the default block above it.

# ---- Option A: Google Gemini (default; needs a Gemini API key) ----
LLM_MODEL=gemini/gemini-2.5-flash
LLM_API_KEY=your-gemini-api-key-here

# ---- Option B: OpenAI (uncomment to use instead of Gemini) ----
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-your-openai-api-key-here

# ---- Option C: Azure OpenAI (uncomment to use instead of Gemini) ----
# LiteLLM expects the model name prefixed with "azure/" followed by your
# Azure *deployment name* (not the underlying model name, e.g. "gpt-4o").
# You also need the endpoint and API version from your Azure resource.
# LLM_MODEL=azure/your-deployment-name
# LLM_API_KEY=your-azure-api-key-here
# AZURE_API_BASE=https://your-resource-name.openai.azure.com/
# AZURE_API_VERSION=2024-06-01

# --- Findings LLM (per-finding explanations; defaults to local Ollama) ---
# If you don't have Ollama running locally (e.g. you only have an OpenAI/Azure
# key), point this at the SAME provider you configured above instead:
FINDINGS_LLM_MODEL=ollama_chat/llama3.1:8b
FINDINGS_LLM_API_BASE=http://localhost:11434

# ---- Option B: OpenAI (uncomment to use instead of local Ollama) ----
# FINDINGS_LLM_MODEL=gpt-4o-mini
# FINDINGS_LLM_API_BASE=
# (LLM_API_KEY above is reused automatically as the findings key too — see
# app/config.py for the fallback logic.)

# ---- Option C: Azure OpenAI (uncomment to use instead of local Ollama) ----
# FINDINGS_LLM_MODEL=azure/your-deployment-name
# FINDINGS_LLM_API_BASE=
# AZURE_API_BASE=https://your-resource-name.openai.azure.com/
# AZURE_API_VERSION=2024-06-01

# Skip litellm's startup fetch of its remote model-pricing map (saves ~20s+
# per process start, longer/hangs on restricted networks). Set in code too
# (app/llm/client.py) but harmless/explicit to also set here.
LITELLM_LOCAL_MODEL_COST_MAP=True

# --- Audit Configuration ---
MATERIALITY_THRESHOLD=50000
DORMANT_VENDOR_DAYS=180
NEW_VENDOR_WINDOW_DAYS=30
NEW_VENDOR_HIGH_VALUE=10000
VENDOR_CONCENTRATION_PCT=40
BENFORD_P_VALUE=0.05
OUTLIER_ZSCORE_THRESHOLD=3.0
SPLIT_TRANSACTION_WINDOW_DAYS=1

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=true
